{
  "name": "orbit-deck",
  "productName": "Orbit Deck",
  "version": "0.2.0",
  "description": "Desktop shell for orbit - tree explorer, live tree-health dashboard, and an embedded Claude agent panel. No server: everything runs local against your orbit root.",
  "main": "main.js",
  "author": "mostlytricks",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node tests/deck-smoke.js",
    "dist:win": "electron-builder --win zip",
    "dist:win:dir": "electron-builder --win dir"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "playwright-core": "^1.61.1"
  },
  "build": {
    "appId": "dev.mostlytricks.orbitdeck",
    "productName": "OrbitDeck",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**",
      "renderer/**",
      "package.json"
    ],
    "win": {
      "target": [
        "zip"
      ]
    }
  }
}
